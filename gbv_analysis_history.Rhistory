cat("KEY FINDINGS\n")
cat("───────────────────────────────────────────────────────────────────────────\n\n")
cat("1. PREVALENCE (Phase 1 - Descriptive Epidemiology)\n")
cat(sprintf("   • Overall GBV prevalence: %.1f%% (95%% CI: %.1f-%.1f%%)\n",
prevalence_overall$Prevalence_pct[1],
prevalence_overall$CI_lower[1],
prevalence_overall$CI_upper[1]))
cat("   • Prevalence varies significantly by demographic subgroups\n")
cat("   • Higher burden in vulnerable populations\n\n")
