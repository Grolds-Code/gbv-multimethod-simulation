cat("of complex mediation pathways, underscores the need for integrated,\n")
cat("multi-level prevention strategies addressing both individual behaviors\n")
cat("and structural determinants of violence.\n\n")
cat("═══════════════════════════════════════════════════════════════════════════\n")
cat("Analysis completed:", format(Sys.Date(), "%B %d, %Y"), "\n")
cat("Total analytical phases: 5\n")
cat("Final sample size:", nrow(data_sim), "\n")
cat("Primary outcome: Any lifetime GBV experience\n")
cat("═══════════════════════════════════════════════════════════════════════════\n")
sink()
cat("✅ Executive summary created\n\n")
# Save your entire workspace
save.image("gbv_analysis_workspace.RData")
# Save your command history
savehistory("gbv_analysis_history.Rhistory")
