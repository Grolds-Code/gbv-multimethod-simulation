nrow(sig_pathways), nrow(all_pathways)))
if(nrow(sig_pathways) > 0) {
cat("   • Key mechanisms identified:\n")
for(i in 1:nrow(sig_pathways)) {
cat(sprintf("     • %s (%.1f%% mediated)\n",
sig_pathways$Pathway[i],
sig_pathways$Prop_Mediated[i] * 100))
}
} else {
