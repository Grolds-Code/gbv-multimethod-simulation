cat(sprintf("   • Random Forest model accuracy: %.1f%%\n",
rf_performance$Value[rf_performance$Metric == "Accuracy"] * 100))
cat(sprintf("   • Model discrimination (AUC): %.3f\n",
rf_performance$Value[rf_performance$Metric == "AUC"]))
