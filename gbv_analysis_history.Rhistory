arrange(desc(abs(estimate - 1))) %>%
mutate(
OR_CI = sprintf("%.2f (%.2f-%.2f)", estimate, conf.low, conf.high),
p_formatted = ifelse(p.value < 0.001, "<0.001", sprintf("%.3f", p.value))
) %>%
select(Risk_Factor = term, OR_95CI = OR_CI, P_value = p_formatted,
Effect = direction)
